# Simulate Tufte data for barplot
df <- data.frame(
x = 1:12,
y = c(8.7, 11.6, 6.4, 7.1, 2.6, 17.8,
13.3, 8.5, 5.8, 10.8, 4.9, 9.5)
)
# Default barplot
df |> ggplot(aes(x, y)) +
geom_bar()
pacman::p_load(tidyverse, ggthemes, MetBrewer, sysfonts, showtext)
# Default barplot
df |> ggplot(aes(x, y)) +
geom_bar()
# Default barplot
df |> ggplot(aes(x = x, y = y)) +
geom_bar()
# Default barplot
df |> ggplot(aes(x = x, y = y)) +
geom_col()
# Chunk 1: setup
knitr::opts_chunk$set(echo = TRUE,
message = FALSE,
warning = FALSE,
out.width = "70%")
library(gapminder)  # for gapminder
library(tidyverse)  # for everything
library(ggthemes)   # for additional themes (e.g., theme_tufte)
library(MetBrewer)  # for curated color palettes
library(sysfonts)   # for grabbing Google fonts
library(showtext)   # for rendering Google fonts
library(gridExtra)  # for arranging 2+ ggplots
gapminder <- gapminder
# Chunk 3
q <- ggplot(
gapminder,                   # data
aes(gdpPercap, lifeExp)) +   # aesthetics
geom_point()                           # geoms
# Chunk 4
q
# Chunk 5
p <- q +
# fix scales
scale_x_log10(labels = scales::label_dollar()) +
# fix labels
labs(x = "\nGDP Per Capita (USD)",
y = "Life Expectancy (Years)\n",
title = "Economic Development Is Linked to Life Expectancy\n")
# Chunk 6
p
# Chunk 7
p <- p +
# remove gray plot background and ticks
theme_minimal() +
theme(
# remove minor grid lines
panel.grid.minor = element_blank(),
# minimize major grid lines
panel.grid.major = element_line(linetype = "dotted", color = "gray70")
)
# Chunk 8
p
# Chunk 9
gridExtra::grid.arrange(q, p, ncol = 2, padding = unit(2, "line"))
# Chunk 11
p <- ggplot(gapminder,                                    # data
aes(gdpPercap, lifeExp, color = continent)) + # aesthetics
geom_point(alpha = .7) +                                # geoms
# scales and labels
scale_x_log10(labels = scales::label_dollar()) +
labs(x = "\nGDP Per Capita (USD)",
y = "Life Expectancy (Years)\n",
title = "Economic Development Is Linked to Life Expectancy\n",
color = "Continent") +
# theme
theme_minimal() +
theme(panel.grid.minor = element_blank(),
panel.grid.major = element_line(linetype = "dotted", color = "gray70")) +
# color as emphasis
# combine with color aesthetic
scale_color_met_d(name = "Johnson")
# Chunk 12
p
# Chunk 13
library(sysfonts)
library(showtext)
# Add my current favorite DataViz font
font_add_google("Raleway", family = "raleway")
showtext_auto()
p <- p + theme(text = element_text(family = "raleway"))
# Chunk 14
p
p_bad <- ggplot(gapminder |> filter(year == 2007),
aes(x = reorder(country, lifeExp),
y = lifeExp,
fill = continent)) +
geom_col() +
coord_flip() +
labs(title = "Life Expectancy by Country in 2007",
x = "Country",
y = "Life Expectancy")
library(here)
library(tidyverse)
library(readr)
dat <- read.csv("https://raw.githubusercontent.com/rfordatascience/tidytuesday/master/data/2019/2019-09-24/school_diversity.csv")
rural_dat <- dat %>%
filter(d_Locale_Txt %in% c("town-distant",
"town-remote",
"town-fringe",
"town-small",
"rural-distant",
"rural-remote",
"rural-fringe",
"rural-small",
"rural-midsize",
"rural-large"))
View(rural_dat)
filtered_dat <- rural_dat %>%
select(LEAID, LEA_NAME, SCHOOL_YEAR, White) %>%
pivot_wider(names_from = SCHOOL_YEAR, values_from = White) %>%
rename(white_1995 = '1994-1995', white_2017 = '2016-2017') %>%
mutate(white_change = white_2017 - white_1995) %>%
drop_na()
View(filtered_dat)
View(rural_dat)
View(filtered_dat)
#average percentage change in proportion white student, percentage of counties with decreasing white population
p <- ggplot(filtered_dat,
aes(x = reorder(LEA_NAME, white_change),
y = white_change)) +
geom_col(color = "red")
p
ggplot(filtered_dat,
aes(reoder(LEAID, white_change),
white_change)) +
geom_col()
ggplot(filtered_dat,
aes(reorder(LEAID, white_change),
white_change)) +
geom_col()
length(unique(filter_dat$LEAID))
length(unique(filtered_dat$LEAID))
length(unique(filtered_dat$LEA_NAME))
ggplot(filtered_dat,
aes(white_change)) +
geom_histogram()
ggplot(filtered_dat,
aes(white_change)) +
geom_col()
#load relevant libraries
library(dplyr)
library(tidyverse)
library(scales)
library(viridis)
library(patchwork)
#load data
data <- read.csv("https://raw.githubusercontent.com/rfordatascience/tidytuesday/master/data/2019/2019-09-24/school_diversity.csv")
VA_Schools <- data %>%
filter(ST == "VA")
VA_Region <- VA_Schools %>%
mutate(
d_Locale_Txt = case_when(
d_Locale_Txt %in% c("city-large", "city-small", "city-midsize") ~ "urban",
d_Locale_Txt %in% c("rural-distant", "rural-fringe", "rural-remote") ~ "rural",
d_Locale_Txt %in% c("town-distant", "town-fringe", "town-remote") ~ "town",
TRUE ~ "suburban"))
VA_Region$diverse_num <- with(
VA_Region,
ifelse(diverse == "Diverse",              3,
ifelse(diverse == "Undiverse",            2,
ifelse(diverse == "Extremely undiverse",  1, NA))))
View(VA_Region)
View(VA_Schools)
View(VA_Region)
#Create first deceptive graph by making the average variable to use as the end points for each region. Omitted portion can show value labels on either end of the data points, like the one example from class, but I think it's more deceptive without any labels.
VA_Region_avg <- VA_Region |>
group_by(d_Locale_Txt, SCHOOL_YEAR) |>
summarise(VA_Region_mean = mean(diverse_num, na.rm = TRUE),
.groups = "drop")
View(VA_Region_avg)
View(VA_Region_avg)
#create second graph by scaling, then mapping both y-axis onto the plot
VA_Region_avg$Total <- VA_Region_avg$VA_Region_mean * 10
View(VA_Region_avg)
View(VA_Region_avg)
View(VA_Region_avg)
scale_factor <- max(VA_Region_avg$VA_Region_mean, na.rm = TRUE) /
max(VA_Region_avg$Total, na.rm = TRUE) * 10
head(VA_Region_avg)
deceptive2 <- ggplot(VA_Region_avg, aes(x = SCHOOL_YEAR)) +
geom_line(aes(y = VA_Region_mean, group = 1), color = "violet", linewidth = 1.2) +
geom_line(aes(y = Total * scale_factor, group = 1), color = "lightgreen", linewidth = 1.2) +
geom_point(aes(y = VA_Region_mean), color = "violet", size = 3) +
geom_point(aes(y = Total * scale_factor), color = "lightgreen", size = 3) +
facet_wrap(~ d_Locale_Txt) +
scale_y_continuous(
name = "Diversity Score",
sec.axis = sec_axis(~ . / scale_factor, name = "Enrollment (in 100s)")
) +
theme_minimal() +
theme(
axis.text.y.left = element_text(color = "violet"),
axis.text.y.right = element_text(color = "lightgreen"),
axis.title.y.left = element_text(color = "violet"),
axis.title.y.right = element_text(color = "lightgreen")
) +
labs(title = "Limited Increased Diversity with Increased Enrollment (1994-2017)",
x = "Academic Year")
deceptive2
